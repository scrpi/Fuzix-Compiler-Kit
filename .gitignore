# Generated microcode images — rebuilt from microcode/*.uasm by uasm.py.
# The source of truth is the .uasm + control_word.toml, never the burned bytes.
microcode/build/

# Python
__pycache__/
*.pyc

# Simulation artifacts (the sims build into /tmp, but guard the tree anyway)
*.vcd
*.fst
*.vvp
obj_dir/

# Generated visualization (rebuilt from hdl/ by tools/viz/ — toolchain.md P3)
tools/viz/build/
# Logisim Evolution: the .circ is now hand-edited and reconciled against the HDL (tracked,
# like a KiCad PCB) — only the intermediate Yosys netlist is generated/disposable.
logisim/build/*.netlist.json
# Logisim Evolution scratch: per-file autosave snapshots + JVM crash dumps
*.autosave
hs_err_pid*.log
# Installed node deps for the viz tools (declared in tools/viz/package.json)
tools/viz/node_modules/

# Windows / WSL download metadata (alternate-data-stream sidecars)
*:Zone.Identifier
