	jmp %1
%1:
=
%1:

	jsr %1
;:
	rts
=
	jmp %1

#
#	Peephole the common load local via tmp
#

	lda (@sp),y
	tax
	lda (@sp)
	sta @tmp
	stx @tmp+1
=
	jsr __lxa0sptmp

	lda (@sp),y
	tax
	dey
	lda (@sp),y
	sta @tmp
	stx @tmp+1
=
	jsr __lxaysptmp

	jsr __asp
	sta @tmp
	stx @tmp+1
=
	jsr __asptmp

	lda #0
	jsr __asptmp
=
	jsr __sptmp


	jsr __gloy
	jsr __push
=
	jsr __pushly

	jsr __gloy%1
	jsr __push
=
	jsr __pushly%1

	jsr __gloy
	sta @tmp
	stx @tmp+1
=
	jsr __gloytmp

	jsr __gloy%1
	sta @tmp
	stx @tmp+1
=
	jsr __gloytmp%1

	jsr __gloyl
	jsr __pushl
=
	jsr __pushlyl

	jsr __gloyl0
	jsr __pushl
=
	jsr __pushly0l

	lda (@sp),y
	jsr __pushc
=
	jsr __pushlyc

	ldx #0
	txa
	jsr __push
=
	jsr __push0

	ldx #0
	lda #1
	jsr __push
=
	jsr __push1

	ldx #255
	txa
	jsr __push
=
	jsr __pushffff

	ldx #0
	lda #%1
	jsr __push
=
	lda #%1
	jsr __push0a

#
#	Deref versions for common case. These ought to be implemented
#	in the compiler itself by folding the subtree perhaps ?
#	Push form needs to peephole but the rest should not
#
	jsr __gloytmp
	ldx #0
	lda (@tmp,x)
=
	jsr __gloytmpd1

	jsr __gloytmpd1
	jsr __push
=
	jsr  __pushyd1

	jsr __gloytmp
	ldy #1
	lda (@tmp),y
	tax
	dey
	lda (@tmp),y
=
	jsr __gloytmpd2

	jsr __gloytmpd2
	jsr __push
=
	jsr __pushyd2

#
#	Fold pushes (iffy - reg tracking.. needs better review TODO)
#
	lda #%1
	jsr __pushc
	lda #%2
	jsr __pushc
;invalidate regs
=
	lda #%2
	ldx #%1
	jsr __push
;invalidate regs

#
#	ASP related rules
#

	jsr __asp
	jsr __push
=
	jsr __pasp

	jsr __asp
;invalidate regs
	jsr __derefl
=
	jsr __derefl_a

	jsr __asp
;invalidate regs
	jsr __dereff
=
	jsr __dereff_a

#
#	Minor folding
#
	jsr __deref
	jsr __push
=
	jsr __pderef

#
#	Push register
#
	lda @reg1
	ldx @reg1+1
	jsr __push
=
	jsr __pushr1

	lda @reg2
	ldx @reg2+1
	jsr __push
=
	jsr __pushr2

	lda @reg3
	ldx @reg3+1
	jsr __push
=
