+/*
+ * Set up the symbol table.
+ * Sweep through the initializations
+ * of the "phash", and link them into the
+ * buckets. Because it is here, a
+ * "sizeof" works.
+ */
+void syminit(void)
+{
+	SYM *sp;
+	int hash;
+
+	sp = &sym[0];
+	while (sp < &sym[sizeof(sym)/sizeof(SYM)]) {
+		hash = symhash(sp->s_id);
+		sp->s_fp = phash[hash];
+		phash[hash] = sp;
+		++sp;
+	}
+}
