+/*
+ * Set up the symbol table: link each entry into the predefined-symbol hash.
+ */
+void syminit(void)
+{
+	SYM *sp;
+	int hash;
+
+	sp = &sym[0];
+	while (sp < &sym[sizeof(sym)/sizeof(SYM)]) {
+		hash = symhash(sp->s_id);
+		sp->s_fp = phash[hash];
+		phash[hash] = sp;
+		++sp;
+	}
+}
