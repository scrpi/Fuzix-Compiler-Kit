+/*
+ * Make sure the mode/register fields of the ADDR can take part in an add or
+ * subtract (used by the shared expression evaluator).
+ */
+void isokaors(ADDR *ap, int paren)
+{
+	int mode;
+
+	mode = ap->a_type&TMMODE;
+	if (mode == TUSER)
+		return;
+	aerr(ADDR_REQUIRED);
